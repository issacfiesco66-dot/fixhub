# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/fixhub?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/fixhub?schema=public"

# --- Auth ---
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LEAD_PRICE_MXN="450"
LEAD_LOCK_SECONDS="60"

# OpenAI — Geo-SEO content generator
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Gate del seed para cuentas demo (admin@fixhub.mx / tecnico@fixhub.mx con demo1234)
# Solo "true" en desarrollo local. NUNCA en producción.
FIXHUB_SEED_DEMO="false"
