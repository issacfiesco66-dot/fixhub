# ─────────────────────────────────────────────────────────────────
# FixHub — .gitignore
# ─────────────────────────────────────────────────────────────────

# Dependencias
node_modules/
.pnpm-store/
.yarn/cache
.yarn/install-state.gz
jspm_packages/
bower_components/

# Build / cache de Next.js y bundlers
.next/
out/
dist/
build/
.turbo/
.swc/
.vercel/

# Caché TypeScript
*.tsbuildinfo
next-env.d.ts.bak

# ⚠️ Secretos y configuración local — NUNCA commitear
# OpenAI / Stripe / DB credentials viven aquí
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.envrc

# Logs
*.log
dev.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log

# Reportes de cobertura
coverage/
*.lcov
.nyc_output/

# Bases de datos locales (si alguien usara SQLite)
*.sqlite
*.sqlite3
*.db
prisma/migrations/dev.db*
prisma/*.db
prisma/*.db-journal

# Sistema operativo
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# IDEs y editores
.idea/
.vscode/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Carpeta de configuración interna de Claude Code (memoria + sesión)
.claude/

# Archivos temporales del propio Next dev
.tmp/
*.pid
*.seed
*.pid.lock
security/

.vercel
.env*.local
