# Variables de entorno del FixHub Scraper Service (Railway)

# Token que FixHub envía en cada request (debe ser IGUAL a SCRAPER_SERVICE_TOKEN
# configurado en Vercel). Mínimo 16 chars.
SCRAPER_SERVICE_TOKEN=

# A dónde el scraper postea los prospectos (endpoint de ingest de FixHub) y el
# secret de ese endpoint (debe ser IGUAL a INGEST_WEBHOOK_SECRET en Vercel).
FIXHUB_INGEST_URL=https://fixhub-sigma.vercel.app/api/prospectos/ingest
INGEST_WEBHOOK_SECRET=

# Orígenes permitidos para CORS (separados por coma). Opcional.
CORS_ORIGINS=https://fixhub-sigma.vercel.app

# Puerto (Railway lo inyecta solo; default 8000).
# PORT=8000
